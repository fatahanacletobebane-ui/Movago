  input::placeholder{color:rgba(255,255,255,0.3)}
  
  /* Profile Card */
  .profile-card{background:var(--glass);border-radius:20px;padding:24px;margin-bottom:20px;text-align:center;border:1px solid rgba(255,255,255,0.05)}
  .profile-avatar{width:80px;height:80px;border-radius:50%;background:var(--gradient-hero);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;font-size:36px;font-weight:700;box-shadow:0 8px 32px rgba(255,107,0,0.3)}
  .profile-name{font-size:20px;font-weight:700;margin-bottom:4px}
  .profile-phone{color:var(--text-secondary);font-size:14px;margin-bottom:16px}
  .profile-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:16px;padding-top:16px;border-top:1px solid rgba(255,255,255,0.05)}
  .profile-stat{text-align:center}
  .profile-stat-value{font-size:24px;font-weight:700;color:var(--primary)}
  .profile-stat-label{font-size:11px;color:var(--text-secondary);text-transform:uppercase}
  
  /* Menu */
  .menu-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin-bottom:20px}
  .menu-item{background:var(--glass);border-radius:16px;padding:20px;text-align:center;cursor:pointer;transition:all 0.3s;border:1px solid rgba(255,255,255,0.05)}
  .menu-item:hover{background:rgba(255,255,255,0.08);transform:translateY(-2px)}
  .menu-item-icon{font-size:28px;margin-bottom:8px}
  .menu-item-label{font-size:13px;font-weight:500}
  
  /* Trip Form */
  .autocompleteList{position:absolute;top:calc(100% + 8px);left:0;right:0;z-index:100;background:rgba(20,20,30,0.98);border:1px solid rgba(255,255,255,0.1);border-radius:16px;max-height:280px;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,0.5);display:none}
  .autocompleteList.active{display:block;animation:slideDown 0.3s ease}
  @keyframes slideDown{from{opacity:0;transform:translateY(-10px)}to{opacity:1;transform:translateY(0)}}
  .autocompleteList ul{list-style:none;padding:8px;margin:0}
  .autocompleteList li{padding:12px 16px;cursor:pointer;border-radius:12px;transition:all 0.2s ease;font-size:14px;display:flex;align-items:center;gap:10px}
  .autocompleteList li:hover{background:rgba(255,107,0,0.15);color:var(--primary-light)}
  
  .info-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin:16px 0}
  .info-box{background:var(--glass);padding:16px;border-radius:16px;text-align:center;border:1px solid rgba(255,255,255,0.05)}
  .info-label{font-size:11px;color:var(--text-secondary);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:4px}
  .info-value{font-size:20px;font-weight:700}
  
  .price-display{background:var(--gradient-hero);border-radius:20px;padding:24px;text-align:center;margin:20px 0;position:relative;overflow:hidden}
  .price-display::before{content:"";position:absolute;inset:0;background:linear-gradient(45deg,transparent 30%,rgba(255,255,255,0.1) 50%,transparent 70%);animation:shimmer 3s infinite}
  @keyframes shimmer{0%{transform:translateX(-100%)}100%{transform:translateX(100%)}}
  .price-label{font-size:12px;text-transform:uppercase;letter-spacing:1px;opacity:0.9;margin-bottom:8px;position:relative}
  .price-value{font-size:42px;font-weight:800;position:relative;text-shadow:0 4px 20px rgba(0,0,0,0.3)}
  .price-currency{font-size:20px;font-weight:600;opacity:0.9}
  
  /* Buttons */
  .actionBtn{width:100%;padding:16px;border:none;border-radius:16px;cursor:pointer;font-size:15px;font-weight:600;margin-top:12px;transition:all 0.3s ease;display:flex;align-items:center;justify-content:center;gap:10px;position:relative;overflow:hidden}
  .actionBtn::before{content:"";position:absolute;inset:0;background:linear-gradient(45deg,transparent 30%,rgba(255,255,255,0.2) 50%,transparent 70%);transform:translateX(-100%);transition:transform 0.6s}
  .actionBtn:hover::before{transform:translateX(100%)}
  .actionBtn:disabled{opacity:0.5;cursor:not-allowed}
  .btn-primary{background:linear-gradient(135deg,var(--primary) 0%,var(--primary-light) 100%);color:#fff;box-shadow:0 8px 32px rgba(255,107,0,0.3)}
  .btn-primary:hover:not(:disabled){transform:translateY(-2px);box-shadow:0 12px 40px rgba(255,107,0,0.4)}
  .btn-success{background:linear-gradient(135deg,var(--accent) 0%,#00e676 100%);color:#fff;box-shadow:0 8px 32px rgba(0,200,83,0.3)}
  .btn-secondary{background:rgba(255,255,255,0.1);color:#fff;border:1px solid rgba(255,255,255,0.1)}
  .btn-danger{background:linear-gradient(135deg,var(--danger) 0%,#ff6b81 100%);color:#fff}
  
  /* Status Cards */
  .status-card{background:var(--glass);border-radius:20px;padding:20px;margin-bottom:16px;border:1px solid rgba(255,255,255,0.05);position:relative;overflow:hidden}
  .status-card::before{content:"";position:absolute;top:0;left:0;width:4px;height:100%;background:var(--gradient-hero)}
  .status-header{display:flex;align-items:center;gap:12px;margin-bottom:16px}
  .status-badge{padding:6px 12px;border-radius:20px;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px}
  .status-badge.searching{background:rgba(255,193,7,0.2);color:#ffc107}
  .status-badge.accepted{background:rgba(0,200,83,0.2);color:#00c853}
  .status-badge.driving{background:rgba(33,150,243,0.2);color:#2196f3}
  .status-badge.arrived{background:rgba(156,39,176,0.2);color:#9c27b0}
  .status-badge.completed{background:rgba(0,200,83,0.2);color:#00c853}
  
  .driver-info{display:flex;align-items:center;gap:16px;padding:16px;background:rgba(0,0,0,0.2);border-radius:16px;margin-top:16px}
  .driver-avatar{width:56px;height:56px;border-radius:50%;background:var(--gradient-hero);display:flex;align-items:center;justify-content:center;font-size:24px;flex-shrink:0}
  .driver-details{flex:1}
  .driver-name{font-weight:600;font-size:16px;margin-bottom:2px}
  .driver-plate{font-size:13px;color:var(--text-secondary);margin-bottom:4px}
  .driver-rating{display:flex;align-items:center;gap:4px;font-size:13px;color:var(--secondary)}
  .call-btn{width:48px;height:48px;border-radius:50%;background:var(--accent);border:none;color:#fff;font-size:20px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all 0.3s;box-shadow:0 4px 16px rgba(0,200,83,0.3)}
  .call-btn:hover{transform:scale(1.1);box-shadow:0 6px 24px rgba(0,200,83,0.4)}
  
  /* Loading */
  .loading-container{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:40px 20px;text-align:center}
  .spinner{width:80px;height:80px;border-radius:50%;border:4px solid rgba(255,107,0,0.1);border-top-color:var(--primary);animation:spin 1s linear infinite;margin-bottom:24px;position:relative}
  .spinner::before{content:"";position:absolute;inset:-8px;border-radius:50%;border:4px solid transparent;border-top-color:var(--secondary);animation:spin 2s linear infinite reverse}
  @keyframes spin{to{transform:rotate(360deg)}}
  
  /* Toast */
  .toast-container{position:fixed;top:20px;left:50%;transform:translateX(-50%);z-index:10000;display:flex;flex-direction:column;gap:8px;pointer-events:none}
  .toast{background:rgba(30,30,40,0.95);color:#fff;padding:14px 24px;border-radius:12px;font-size:14px;font-weight:500;backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,0.1);box-shadow:0 10px 40px rgba(0,0,0,0.3);display:flex;align-items:center;gap:10px;pointer-events:auto;animation:toast-in 0.3s ease;min-width:300px;justify-content:center}
  @keyframes toast-in{from{opacity:0;transform:translateX(-50%) translateY(-20px)}to{opacity:1;transform:translateX(-50%) translateY(0)}}
  .toast.success{border-left:4px solid var(--accent)}
  .toast.error{border-left:4px solid var(--danger)}
  
  /* History List */
  .history-list{display:flex;flex-direction:column;gap:12px}
  .history-item{background:var(--glass);border-radius:16px;padding:16px;border:1px solid rgba(255,255,255,0.05);display:flex;align-items:center;gap:16px}
  .history-icon{width:48px;height:48px;border-radius:50%;background:rgba(255,255,255,0.05);display:flex;align-items:center;justify-content:center;font-size:24px}
  .history-details{flex:1}
  .history-route{font-weight:600;margin-bottom:4px;font-size:14px}
  .history-meta{font-size:12px;color:var(--text-secondary);display:flex;gap:12px}
  .history-price{font-weight:700;color:var(--secondary);font-size:16px}
  
  /* Rating */
  .rating-container{display:flex;flex-direction:column;align-items:center;gap:16px;padding:24px;background:var(--glass);border-radius:20px;margin-top:16px}
  .stars{display:flex;gap:8px}
  .star{font-size:32px;color:rgba(255,255,255,0.2);cursor:pointer;transition:all 0.2s}
  .star.active{color:var(--secondary);text-shadow:0 0 20px var(--secondary)}
  .star:hover{transform:scale(1.2)}
</style>
</head>
<body>
  <div class="toast-container" id="toastContainer"></div>
  
  <div class="app">
    <div class="header">
      <div class="logo-container">
        <div class="logo-icon">🚗</div>
        <div class="logo-text">
          <h1>MovaGo</h1>
          <span id="pageTitle">Passageiro</span>
        </div>
      </div>
      <div class="user-menu" id="userMenu" style="display:none">
        <div class="user-avatar" id="userAvatar" onclick="showProfile()">
          <span id="userInitial">?</span>
          <div class="status-indicator"></div>
        </div>
      </div>
    </div>
    
    <div class="content" id="mainContent">
      
      <!-- LOGIN -->
      <div class="section active" id="loginSection">
        <div class="login-screen">
          <div class="login-icon">🚕</div>
          <h2>Bem-vindo ao MovaGo</h2>
          <p>Transporte rápido e seguro em Maputo e Matola</p>
          
          <div class="formGroup" style="max-width:320px">
            <label>📱 Número de Telefone</label>
            <div class="input-wrapper">
              <span class="input-icon">🇲🇿</span>
              <input type="tel" id="loginPhone" placeholder="84XXXXXXX" maxlength="9" />
            </div>
          </div>
          
          <div class="formGroup" style="max-width:320px">
            <label>🔒 PIN (4 dígitos)</label>
            <div class="input-wrapper">
              <span class="input-icon">🔐</span>
              <input type="password" id="loginPin" placeholder="****" maxlength="4" />
            </div>
          </div>
          
          <button class="actionBtn btn-primary" onclick="login()" style="max-width:320px">
            <span>🚀</span> Entrar
          </button>
          
          <p style="margin-top:24px;font-size:12px;color:var(--text-secondary)">
            Primeira vez? Cria conta automática
          </p>
        </div>
      </div>
      
      <!-- MAIN MENU -->
      <div class="section" id="menuSection">
        <div class="profile-card">
          <div class="profile-avatar" id="profileAvatar">👤</div>
          <div class="profile-name" id="profileName">Nome</div>
          <div class="profile-phone" id="profilePhone">84XXXXXXX</div>
          <div class="profile-stats">
            <div class="profile-stat">
              <div class="profile-stat-value" id="statTrips">0</div>
              <div class="profile-stat-label">Viagens</div>
            </div>
            <div class="profile-stat">
              <div class="profile-stat-value" id="statRating">5.0</div>
              <div class="profile-stat-label">Avaliação</div>
            </div>
            <div class="profile-stat">
              <div class="profile-stat-value" id="statPoints">0</div>
              <div class="profile-stat-label">Pontos</div>
            </div>
          </div>
        </div>
        
        <div class="menu-grid">
          <div class="menu-item" onclick="showTripForm()">
            <div class="menu-item-icon">🚕</div>
            <div class="menu-item-label">Nova Viagem</div>
          </div>
          <div class="menu-item" onclick="showHistory()">
            <div class="menu-item-icon">📋</div>
            <div class="menu-item-label">Histórico</div>
          </div>
          <div class="menu-item" onclick="showFavorites()">
            <div class="menu-item-icon">⭐</div>
            <div class="menu-item-label">Favoritos</div>
          </div>
          <div class="menu-item" onclick="showSettings()">
            <div class="menu-item-icon">⚙️</div>
            <div class="menu-item-label">Definições</div>
          </div>
        </div>
        
        <button class="actionBtn btn-secondary" onclick="logout()">
          <span>🚪</span> Sair da Conta
        </button>
      </div>
      
      <!-- TRIP FORM -->
      <div class="section" id="tripSection">
        <button class="actionBtn btn-secondary" onclick="showMenu()" style="margin-bottom:16px">
          <span>←</span> Voltar
        </button>
        
        <div class="formGroup">
          <label>📍 Local de Recolha</label>
          <div class="input-wrapper">
            <span class="input-icon">🛣️</span>
            <input type="text" id="pickup" placeholder="Ex: Av. 24 de Julho" autocomplete="off" />
          </div>
          <div id="pickupList" class="autocompleteList"></div>
        </div>
        
        <div class="formGroup">
          <label>🎯 Destino</label>
          <div class="input-wrapper">
            <span class="input-icon">📍</span>
            <input type="text" id="destination" placeholder="Ex: Av. Marginal" autocomplete="off" />
          </div>
          <div id="destList" class="autocompleteList"></div>
        </div>
        
        <div class="info-grid">
          <div class="info-box">
            <div class="info-label">Distância</div>
            <div class="info-value" id="distanceText">— km</div>
          </div>
          <div class="info-box">
            <div class="info-label">Tempo Est.</div>
            <div class="info-value" id="timeText">— min</div>
          </div>
        </div>
        
        <div class="price-display" id="priceDisplay" style="display:none">
          <div class="price-label">Preço Estimado</div>
          <div class="price-value">
            <span id="priceText">0</span>
            <span class="price-currency">MTN</span>
          </div>
        </div>
        
        <button class="actionBtn btn-primary" id="calcBtn" onclick="calculateTrip()">
          <span>🧮</span> Calcular Rota
        </button>
        <button class="actionBtn btn-success" id="requestBtn" onclick="requestTrip()" style="display:none">
          <span>🚕</span> Pedir Viagem
        </button>
      </div>
      
      <!-- SEARCHING DRIVER -->
      <div class="section" id="searchingSection">
        <div class="loading-container">
          <div class="spinner"></div>
          <div class="loading-text">À procura de motoristas...</div>
          <div class="loading-subtext">Por favor aguarde enquanto encontramos o melhor motorista para si</div>
          <button class="actionBtn btn-danger" onclick="cancelRequest()" style="margin-top:32px">
            <span>❌</span> Cancelar Pedido
          </button>
        </div>
      </div>
      
      <!-- ACTIVE TRIP -->
      <div class="section" id="activeTripSection">
        <div id="activeTripContent"></div>
      </div>
      
      <!-- COMPLETED TRIP -->
      <div class="section" id="completedSection">
        <div class="status-card" style="text-align:center">
          <div style="font-size:60px;margin-bottom:16px">🎉</div>
          <h3 style="margin-bottom:8px">Viagem Concluída!</h3>
          <p style="color:var(--text-secondary);margin-bottom:20px">Obrigado por usar MovaGo</p>
          
          <div class="price-display" style="margin:20px 0">
            <div class="price-label">Total a Pagar</div>
            <div class="price-value">
              <span id="finalPrice">0</span>
              <span class="price-currency">MTN</span>
            </div>
          </div>
          
          <div class="rating-container">
            <p style="margin-bottom:8px">Como foi a sua viagem?</p>
            <div class="stars" id="ratingStars">
              <span class="star" onclick="rateTrip(1)">★</span>
              <span class="star" onclick="rateTrip(2)">★</span>
              <span class="star" onclick="rateTrip(3)">★</span>
              <span class="star" onclick="rateTrip(4)">★</span>
              <span class="star" onclick="rateTrip(5)">★</span>
            </div>
            <p style="font-size:12px;color:var(--text-secondary);margin-top:8px" id="ratingText">Toque nas estrelas para avaliar</p>
          </div>
          
          <button class="actionBtn btn-primary" onclick="finishTrip()" style="margin-top:24px">
            <span>✓</span> Concluir
          </button>
        </div>
      </div>
      
      <!-- HISTORY -->
      <div class="section" id="historySection">
        <button class="actionBtn btn-secondary" onclick="showMenu()" style="margin-bottom:16px">
          <span>←</span> Voltar
        </button>
        <h3 style="margin-bottom:16px">📋 Histórico de Viagens</h3>
        <div class="history-list" id="historyList">
          <div class="loading-container">
            <div class="spinner" style="width:40px;height:40px"></div>
            <p>A carregar...</p>
          </div>
        </div>
      </div>
      
    </div>
  </div>

