// UTILITIES
function showToast(msg, type='info'){
  const container = document.getElementById('toastContainer');
  const toast = document.createElement('div');
  toast.className = `toast ${type}`;
  toast.innerHTML = `<span>${type==='success'?'✓':'✗'}</span> ${msg}`;
  container.appendChild(toast);
  setTimeout(()=>toast.remove(), 4000);
}

function showSection(id){
  document.querySelectorAll('.section').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

function norm(s){ return s.toString().trim().toLowerCase(); }
function haversineKm(lat1,lon1,lat2,lon2){
  const R=6371, toRad=d=>d*Math.PI/180;
  const dLat=toRad(lat2-lat1), dLon=toRad(lon2-lon1);
  const a=Math.sin(dLat/2)**2+Math.cos(toRad(lat1))*Math.cos(toRad(lat2))*Math.sin(dLon/2)**2;
  return R*2*Math.atan2(Math.sqrt(a),Math.sqrt(1-a));
}
function calcPrice(km){ return km<=3?100:100+(Math.ceil(km)-3)*25; }
function estimateTime(km){ return Math.ceil(km*2); }

// AUTH
function checkStoredLogin(){
  const phone = localStorage.getItem('movago_phone');
  const pin = localStorage.getItem('movago_pin');
  if(phone && pin){
    document.getElementById('loginPhone').value = phone;
    document.getElementById('loginPin').value = pin;
    login(phone, pin);
  }
}

function login(phone, pin){
  phone = phone || document.getElementById('loginPhone').value.trim();
  pin = pin || document.getElementById('loginPin').value.trim();
  
  if(!phone || phone.length<9){ showToast('Telefone inválido','error'); return; }
  if(!pin || pin.length!==4){ showToast('PIN deve ter 4 dígitos','error'); return; }
  
  db.ref('users/'+phone).once('value').then(snap=>{
    if(snap.exists()){
      const user = snap.val();
      if(user.pin === pin){
        currentUser = user;
        localStorage.setItem('movago_phone', phone);
        localStorage.setItem('movago_pin', pin);
        showMenu();
        showToast('Bem-vindo, '+user.name+'!','success');
      }else{
        showToast('PIN incorreto','error');
      }
    }else{
      // Create new user
      const newUser = {
        phone: phone,
        pin: pin,
        name: 'Passageiro '+phone.slice(-4),
        rating: 5.0,
        totalTrips: 0,
        points: 0,
        createdAt: Date.now(),
        lastLogin: Date.now(),
        favorites: {},
        paymentMethods: {default:'cash',cash:true},
        settings: {notifications:true,language:'pt'}
      };
      db.ref('users/'+phone).set(newUser).then(()=>{
        currentUser = newUser;
        localStorage.setItem('movago_phone', phone);
        localStorage.setItem('movago_pin', pin);
        showMenu();
        showToast('Conta criada!','success');
      });
    }
  });
}

function logout(){
  localStorage.removeItem('movago_phone');
  localStorage.removeItem('movago_pin');
  currentUser = null;
  if(tripListener) tripListener.off();
  location.reload();
}

