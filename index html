 '''<!DOCTYPE html>
<html lang="pt">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>MovaGo — Transporte em Maputo & Matola</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<!-- Firebase SDK -->
<script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-database-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-auth-compat.js"></script>
<style>
  :root{
    --primary:#FF6B00;
    --primary-light:#FF8C42;
    --secondary:#FFD700;
    --accent:#00C853;
    --danger:#ff4757;
    --info:#3498db;
    --dark:#0a0a0a;
    --darker:#050505;
    --card-bg:rgba(255,255,255,0.03);
    --glass: rgba(255,255,255,0.06);
    --text-primary:#ffffff;
    --text-secondary:#a0a0a0;
    --gradient-hero: linear-gradient(135deg, #FF6B00 0%, #FFD700 50%, #FF8C42 100%);
    --gradient-bg: linear-gradient(180deg, #0a0a0a 0%, #1a1a2e 50%, #0f0f23 100%);
  }
  
  *{box-sizing:border-box;font-family:'Poppins',system-ui,sans-serif;margin:0;padding:0}
  
  body{
    margin:0; min-height:100vh;
    background: var(--gradient-bg);
    display:flex; align-items:center; justify-content:center; 
    padding:20px; color:var(--text-primary);
    overflow-x:hidden;
  }
  
  .bg-particles{
    position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:0;
  }
  .particle{
    position:absolute;width:4px;height:4px;background:var(--primary);border-radius:50%;
    animation:float 20s infinite;opacity:0.3;
  }
  @keyframes float{
    0%,100%{transform:translateY(100vh) rotate(0deg);opacity:0}
    10%{opacity:0.3}
    90%{opacity:0.3}
    50%{transform:translateY(-10vh) rotate(180deg)}
  }
  
  .app{
    width:100%;max-width:480px;border-radius:24px;overflow:hidden;
    box-shadow:0 25px 80px rgba(255,107,0,0.15), 0 0 0 1px rgba(255,255,255,0.05);
    background:var(--card-bg);
    backdrop-filter:blur(20px);
    position:relative;z-index:1;
    border:1px solid rgba(255,255,255,0.08);
    min-height:90vh;
    display:flex;
    flex-direction:column;
  }
  
  /* Header */
  .header{
    display:flex;justify-content:space-between;align-items:center;
    padding:20px;
    background:linear-gradient(180deg, rgba(255,107,0,0.1) 0%, transparent 100%);
    border-bottom:1px solid rgba(255,255,255,0.05);
    flex-shrink:0;
  }
  
  .logo-container{display:flex;align-items:center;gap:12px}
  .logo-icon{
    width:44px;height:44px;border-radius:12px;
    background:var(--gradient-hero);
    display:flex;align-items:center;justify-content:center;
    box-shadow:0 8px 32px rgba(255,107,0,0.3);
    position:relative;overflow:hidden;
  }
  .logo-icon::before{content:"🚗";font-size:22px;z-index:2;position:relative}
  .logo-icon::after{
    content:"";position:absolute;inset:0;
    background:linear-gradient(45deg, transparent 30%, rgba(255,255,255,0.3) 50%, transparent 70%);
    animation:shimmer 3s infinite;
  }
  @keyframes shimmer{
    0%{transform:translateX(-100%)}
    100%{transform:translateX(100%)}
  }
  
  .logo-text h1{
    font-size:26px;font-weight:800;
    background:var(--gradient-hero);
    -webkit-background-clip:text;
    -webkit-text-fill-color:transparent;
    background-clip:text;
    letter-spacing:-0.5px;
    margin:0;
  }
  .logo-text span{font-size:10px;color:var(--text-secondary);font-weight:500;letter-spacing:1px;text-transform:uppercase}
  
  .user-menu{
    display:flex;align-items:center;gap:8px;
  }
  
  .user-avatar{
    width:40px;height:40px;border-radius:50%;
    background:var(--gradient-hero);
    display:flex;align-items:center;justify-content:center;
    font-weight:700;font-size:16px;color:#fff;
    cursor:pointer;position:relative;
  }
  
  .status-indicator{
    position:absolute;bottom:2px;right:2px;width:12px;height:12px;
    border-radius:50%;background:var(--accent);border:2px solid var(--dark);
  }
  .status-indicator.offline{background:var(--text-secondary)}
  .status-indicator.busy{background:var(--danger)}
  
  /* Content */
  .content{
    padding:20px;
    flex:1;
    overflow-y:auto;
    display:flex;
    flex-direction:column;
  }
  
  /* Login Screen */
  .login-screen{
    display:flex;flex-direction:column;align-items:center;justify-content:center;
    min-height:60vh;text-align:center;
  }
  
  .login-icon{
    width:100px;height:100px;border-radius:50%;
    background:var(--gradient-hero);
    display:flex;align-items:center;justify-content:center;
    margin-bottom:24px;box-shadow:0 20px 60px rgba(255,107,0,0.3);
    animation:pulse-glow 2s infinite;
  }
  @keyframes pulse-glow{
    0%,100%{box-shadow:0 20px 60px rgba(255,107,0,0.3)}
    50%{box-shadow:0 20px 80px rgba(255,107,0,0.5)}
  }
  .login-icon::before{content:"🚕";font-size:50px}
  
  .login-screen h2{font-size:24px;margin-bottom:8px}
  .login-screen p{color:var(--text-secondary);margin-bottom:32px;font-size:14px}
  
  /* Form Elements */
  .formGroup{margin-bottom:16px;position:relative;width:100%}
  
  label{
    display:block;margin-bottom:6px;font-size:12px;color:var(--text-secondary);
    font-weight:500;text-transform:uppercase;letter-spacing:0.5px;
  }
  
  .input-wrapper{position:relative}
  .input-icon{
    position:absolute;left:16px;top:50%;transform:translateY(-50%);
    font-size:18px;color:var(--primary);opacity:0.7;
  }
  
  input, select{
    width:100%;padding:14px 16px 14px 48px;font-size:15px;color:#fff;
    background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);
    border-radius:16px;outline:none;transition:all 0.3s ease;
  }
  input:focus, select:focus{
    border-color:var(--primary);
    background:rgba(255,107,0,0.05);
    box-shadow:0 0 0 4px rgba(255,107,0,0.1);
  }
  input::placeholder{color:rgba(255,255,255,0.3)}
  input[type="tel"], input[type="password"]{padding-left:48px}
  
  /* Autocomplete */
  .autocompleteList{
    position:absolute;top:calc(100% + 8px);left:0;right:0;z-index:100;
    background:rgba(20,20,30,0.98);border:1px solid rgba(255,255,255,0.1);
    border-radius:16px;max-height:280px;overflow-y:auto;
    box-shadow:0 20px 60px rgba(0,0,0,0.5);
    display:none;
  }
  .autocompleteList.active{display:block;animation:slideDown 0.3s ease}
  @keyframes slideDown{
    from{opacity:0;transform:translateY(-10px)}
    to{opacity:1;transform:translateY(0)}
  }
  .autocompleteList ul{list-style:none;padding:8px;margin:0}
  .autocompleteList li{
    padding:12px 16px;cursor:pointer;border-radius:12px;
    transition:all 0.2s ease;font-size:14px;
    display:flex;align-items:center;gap:10px;
  }
  .autocompleteList li::before{content:"📍";font-size:14px}
  .autocompleteList li:hover{background:rgba(255,107,0,0.15);color:var(--primary-light)}
  
  /* Trip Status Cards */
  .status-card{
    background:var(--glass);border-radius:20px;padding:20px;margin-bottom:16px;
    border:1px solid rgba(255,255,255,0.05);position:relative;overflow:hidden;
  }
  
  .status-card::before{
    content:"";position:absolute;top:0;left:0;width:4px;height:100%;
    background:var(--gradient-hero);
  }
  
  .status-header{
    display:flex;align-items:center;gap:12px;margin-bottom:16px;
  }
  
  .status-badge{
    padding:6px 12px;border-radius:20px;font-size:11px;font-weight:600;
    text-transform:uppercase;letter-spacing:0.5px;
  }
  .status-badge.searching{background:rgba(255,193,7,0.2);color:#ffc107}
  .status-badge.accepted{background:rgba(0,200,83,0.2);color:#00c853}
  .status-badge.driving{background:rgba(33,150,243,0.2);color:#2196f3}
  .status-badge.arrived{background:rgba(156,39,176,0.2);color:#9c27b0}
  .status-badge.completed{background:rgba(0,200,83,0.2);color:#00c853}
  .status-badge.cancelled{background:rgba(244,67,54,0.2);color:#f44336}
  
  .status-time{font-size:12px;color:var(--text-secondary);margin-left:auto}
  
  .trip-route{
    display:flex;align-items:center;gap:12px;margin-bottom:16px;
  }
  
  .route-dot{
    width:12px;height:12px;border-radius:50%;flex-shrink:0;
  }
  .route-dot.pickup{background:var(--primary);box-shadow:0 0 10px var(--primary)}
  .route-dot.dest{background:var(--secondary);box-shadow:0 0 10px var(--secondary)}
  
  .route-line{
    flex:1;height:2px;background:linear-gradient(90deg, var(--primary), var(--secondary));
    position:relative;
  }
  .route-line::after{
    content:"";position:absolute;inset:0;
    background:linear-gradient(90deg, transparent, rgba(255,255,255,0.5), transparent);
    animation:flow 2s infinite;
  }
  @keyframes flow{
    0%{transform:translateX(-100%)}
    100%{transform:translateX(100%)}
  }
  
  .location-text{font-size:14px;font-weight:500}
  .location-text small{display:block;color:var(--text-secondary);font-size:12px;font-weight:400}
  
  .driver-info{
    display:flex;align-items:center;gap:16px;padding:16px;
    background:rgba(0,0,0,0.2);border-radius:16px;margin-top:16px;
  }
  
  .driver-avatar{
    width:56px;height:56px;border-radius:50%;
    background:var(--gradient-hero);display:flex;align-items:center;justify-content:center;
    font-size:24px;flex-shrink:0;
  }
  
  .driver-details{flex:1}
  .driver-name{font-weight:600;font-size:16px;margin-bottom:2px}
  .driver-plate{font-size:13px;color:var(--text-secondary);margin-bottom:4px}
  .driver-rating{display:flex;align-items:center;gap:4px;font-size:13px;color:var(--secondary)}
  
  .call-btn{
    width:48px;height:48px;border-radius:50%;
    background:var(--accent);border:none;color:#fff;font-size:20px;
    cursor:pointer;display:flex;align-items:center;justify-content:center;
    transition:all 0.3s;box-shadow:0 4px 16px rgba(0,200,83,0.3);
  }
  .call-btn:hover{transform:scale(1.1);box-shadow:0 6px 24px rgba(0,200,83,0.4)}
  
  /* Price Display */
  .price-display{
    background:var(--gradient-hero);border-radius:20px;padding:24px;text-align:center;
    margin:20px 0;position:relative;overflow:hidden;
  }
  .price-display::before{
    content:"";position:absolute;inset:0;
    background:linear-gradient(45deg, transparent 30%, rgba(255,255,255,0.1) 50%, transparent 70%);
    animation:shimmer 3s infinite;
  }
  .price-label{font-size:12px;text-transform:uppercase;letter-spacing:1px;opacity:0.9;margin-bottom:8px;position:relative}
  .price-value{font-size:42px;font-weight:800;position:relative;text-shadow:0 4px 20px rgba(0,0,0,0.3)}
  .price-currency{font-size:20px;font-weight:600;opacity:0.9}
  
  /* Action Buttons */
  .actionBtn{
    width:100%;padding:16px;border:none;border-radius:16px;cursor:pointer;
    font-size:15px;font-weight:600;margin-top:12px;
    transition:all 0.3s ease;display:flex;align-items:center;justify-content:center;gap:10px;
    position:relative;overflow:hidden;
  }
  .actionBtn::before{
    content:"";position:absolute;inset:0;
    background:linear-gradient(45deg, transparent 30%, rgba(255,255,255,0.2) 50%, transparent 70%);
    transform:translateX(-100%);transition:transform 0.6s;
  }
  .actionBtn:hover::before{transform:translateX(100%)}
  .actionBtn:disabled{opacity:0.5;cursor:not-allowed}
  
  .btn-primary{
    background:linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
    color:#fff;box-shadow:0 8px 32px rgba(255,107,0,0.3);
  }
  .btn-primary:hover:not(:disabled){transform:translateY(-2px);box-shadow:0 12px 40px rgba(255,107,0,0.4)}
  
  .btn-success{
    background:linear-gradient(135deg, var(--accent) 0%, #00e676 100%);
    color:#fff;box-shadow:0 8px 32px rgba(0,200,83,0.3);
  }
  .btn-success:hover:not(:disabled){transform:translateY(-2px);box-shadow:0 12px 40px rgba(0,200,83,0.4)}
  
  .btn-danger{
    background:linear-gradient(135deg, var(--danger) 0%, #ff6b81 100%);
    color:#fff;box-shadow:0 8px 32px rgba(255,71,87,0.3);
  }
  
  .btn-secondary{
    background:rgba(255,255,255,0.1);color:#fff;border:1px solid rgba(255,255,255,0.1);
  }
  .btn-secondary:hover{background:rgba(255,255,255,0.15)}
  
  /* Info Grid */
  .info-grid{
    display:grid;grid-template-columns:1fr 1fr;gap:12px;margin:16px 0;
  }
  .info-box{
    background:var(--glass);padding:16px;border-radius:16px;text-align:center;
    border:1px solid rgba(255,255,255,0.05);
  }
  .info-label{font-size:11px;color:var(--text-secondary);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:4px}
  .info-value{font-size:20px;font-weight:700}
  
  /* Loading Animation */
  .loading-container{
    display:flex;flex-direction:column;align-items:center;justify-content:center;
    padding:40px 20px;text-align:center;
  }
  .spinner{
    width:80px;height:80px;border-radius:50%;
    border:4px solid rgba(255,107,0,0.1);
    border-top-color:var(--primary);
    animation:spin 1s linear infinite;margin-bottom:24px;
    position:relative;
  }
  .spinner::before{
    content:"";position:absolute;inset:-8px;border-radius:50%;
    border:4px solid transparent;border-top-color:var(--secondary);
    animation:spin 2s linear infinite reverse;
  }
  @keyframes spin{to{transform:rotate(360deg)}}
  
  .loading-text{font-size:18px;font-weight:600;margin-bottom:8px}
  .loading-subtext{font-size:14px;color:var(--text-secondary)}
  
  .driver-search-animation{
    display:flex;gap:8px;justify-content:center;margin-top:24px;
  }
  .driver-dot{
    width:12px;height:12px;border-radius:50%;background:var(--primary);
    animation:driver-pulse 1.4s infinite ease-in-out both;
  }
  .driver-dot:nth-child(1){animation-delay:-0.32s}
  .driver-dot:nth-child(2){animation-delay:-0.16s}
  @keyframes driver-pulse{
    0%,80%,100%{transform:scale(0.6);opacity:0.5}
    40%{transform:scale(1);opacity:1}
  }
  
  /* Hidden sections */
  .section{display:none}
  .section.active{display:block;animation:fadeIn 0.4s ease}
  @keyframes fadeIn{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
  
  /* Toast Notifications */
  .toast-container{
    position:fixed;top:20px;left:50%;transform:translateX(-50%);z-index:10000;
    display:flex;flex-direction:column;gap:8px;pointer-events:none;
  }
  .toast{
    background:rgba(30,30,40,0.95);color:#fff;padding:14px 24px;border-radius:12px;
    font-size:14px;font-weight:500;backdrop-filter:blur(10px);
    border:1px solid rgba(255,255,255,0.1);box-shadow:0 10px 40px rgba(0,0,0,0.3);
    display:flex;align-items:center;gap:10px;pointer-events:auto;
    animation:toast-in 0.3s ease;min-width:300px;justify-content:center;
  }
  @keyframes toast-in{
    from{opacity:0;transform:translateX(-50%) translateY(-20px)}
    to{opacity:1;transform:translateX(-50%) translateY(0)}
  }
  .toast.success{border-left:4px solid var(--accent)}
  .toast.error{border-left:4px solid var(--danger)}
  .toast.info{border-left:4px solid var(--info)}
  
  /* Rating Stars */
  .rating-container{
    display:flex;flex-direction:column;align-items:center;gap:16px;padding:24px;
    background:var(--glass);border-radius:20px;margin-top:16px;
  }
  .stars{display:flex;gap:8px}
  .star{
    font-size:32px;color:rgba(255,255,255,0.2);cursor:pointer;transition:all 0.2s;
  }
  .star.active{color:var(--secondary);text-shadow:0 0 20px var(--secondary)}
  .star:hover{transform:scale(1.2)}
  
  /* Admin Panel */
  .admin-panel{
    background:rgba(0,0,0,0.3);border-radius:20px;padding:20px;margin-top:20px;
    border:1px solid rgba(255,255,255,0.05);
  }
  .admin-panel h3{font-size:16px;margin-bottom:16px;color:var(--primary)}
  
  /* Scrollbar */
  ::-webkit-scrollbar{width:6px}
  ::-webkit-scrollbar-track{background:transparent}
  ::-webkit-scrollbar-thumb{background:rgba(255,107,0,0.3);border-radius:3px}
  ::-webkit-scrollbar-thumb:hover{background:rgba(255,107,0,0.5)}
  
  /* Responsive */
  @media(max-width:480px){
    body{padding:0}
    .app{border-radius:0;max-width:100%;min-height:100vh;height:100vh}
  }
</style>
</head>
<body>
  <div class="bg-particles" id="particles"></div>
  <div class="toast-container" id="toastContainer"></div>
  
  <div class="app">
    <!-- Header -->
    <div class="header">
      <div class="logo-container">
        <div class="logo-icon"></div>
        <div class="logo-text">
          <h1>MovaGo</h1>
          <span id="userGreeting">Transporte Inteligente</span>
        </div>
      </div>
      <div class="user-menu" id="userMenu" style="display:none">
        <div class="user-avatar" id="userAvatar" onclick="toggleUserMenu()">
          <span id="userInitial">?</span>
          <div class="status-indicator offline" id="userStatus"></div>
        </div>
      </div>
    </div>
    
    <div class="content" id="mainContent">
      
      <!-- LOGIN SECTION -->
      <div class="section active" id="loginSection">
        <div class="login-screen">
          <div class="login-icon"></div>
          <h2>Bem-vindo ao MovaGo</h2>
          <p>Transporte rápido e seguro em Maputo e Matola</p>
          
          <div class="formGroup" style="max-width:320px">
            <label>📱 Número de Telefone</label>
            <div class="input-wrapper">
              <span class="input-icon">🇲🇿</span>
              <input type="tel" id="loginPhone" placeholder="84XXXXXXX" maxlength="9" />
            </div>
          </div>
          
          <div class="formGroup" style="max-width:320px">
            <label>🔒 PIN (4 dígitos)</label>
            <div class="input-wrapper">
              <span class="input-icon">🔐</span>
              <input type="password" id="loginPin" placeholder="****" maxlength="4" />
            </div>
          </div>
          
          <button class="actionBtn btn-primary" onclick="login()" style="max-width:320px">
            <span>🚀</span> Entrar
          </button>
          
          <p style="margin-top:24px;font-size:12px;color:var(--text-secondary)">
            Primeira vez? Insira seus dados para criar conta automaticamente
          </p>
        </div>
      </div>
      
      <!-- MAIN APP SECTION -->
      <div class="section" id="appSection">
        
        <!-- Request Form -->
        <div id="requestForm">
          <div class="formGroup">
            <label>📍 Local de Recolha</label>
            <div class="input-wrapper">
              <span class="input-icon">🛣️</span>
              <input type="text" id="pickup" placeholder="Ex: Av. 24 de Julho" autocomplete="off" />
            </div>
            <div id="pickupList" class="autocompleteList"></div>
          </div>
          
          <div class="formGroup">
            <label>🎯 Destino</label>
            <div class="input-wrapper">
              <span class="input-icon">📍</span>
              <input type="text" id="destination" placeholder="Ex: Av. Marginal" autocomplete="off" />
            </div>
            <div id="destList" class="autocompleteList"></div>
          </div>
          
          <div class="info-grid">
            <div class="info-box">
              <div class="info-label">Distância</div>
              <div class="info-value" id="distanceText">— km</div>
            </div>
            <div class="info-box">
              <div class="info-label">Tempo Est.</div>
              <div class="info-value" id="timeText">— min</div>
            </div>
          </div>
          
          <div class="price-display" id="priceDisplay" style="display:none">
            <div class="price-label">Preço Estimado</div>
            <div class="price-value">
              <span id="priceText">0</span>
              <span class="price-currency">MTN</span>
            </div>
          </div>
          
          <button class="actionBtn btn-primary" id="calcBtn" onclick="calculateTrip()">
            <span>🧮</span> Calcular Rota
          </button>
          
          <button class="actionBtn btn-success" id="requestBtn" onclick="requestTrip()" style="display:none">
            <span>🚕</span> Pedir Viagem
          </button>
        </div>
        
        <!-- Searching for Driver -->
        <div class="loading-container" id="searchingDriver" style="display:none">
          <div class="spinner"></div>
          <div class="loading-text">À procura de motoristas...</div>
          <div class="loading-subtext">Por favor aguarde enquanto encontramos o melhor motorista para si</div>
          <div class="driver-search-animation">
            <div class="driver-dot"></div>
            <div class="driver-dot"></div>
            <div class="driver-dot"></div>
          </div>
          <button class="actionBtn btn-danger" onclick="cancelRequest()" style="margin-top:32px;max-width:200px">
            <span>❌</span> Cancelar Pedido
          </button>
        </div>
        
        <!-- Active Trip Status -->
        <div id="activeTrip" style="display:none">
          <!-- Status will be dynamically inserted here -->
        </div>
        
        <!-- Trip Completed -->
        <div id="tripCompleted" style="display:none">
          <div class="status-card">
            <div style="text-align:center;padding:20px">
              <div style="font-size:60px;margin-bottom:16px">🎉</div>
