// AUTOCOMPLETE
function setupAutocomplete(){
  const pickup = document.getElementById('pickup');
  const dest = document.getElementById('destination');
  
  pickup.addEventListener('input',()=>showSuggestions(pickup,'pickupList'));
  dest.addEventListener('input',()=>showSuggestions(dest,'destList'));
  
  document.addEventListener('click',e=>{
    if(!e.target.closest('.formGroup')){
      document.querySelectorAll('.autocompleteList').forEach(el=>el.classList.remove('active'));
    }
  });
}

function showSuggestions(input,listId){
  const q = input.value.trim().toLowerCase();
  const container = document.getElementById(listId);
  container.innerHTML = '';
  if(q.length<1){container.classList.remove('active');return;}
  
  const ul = document.createElement('ul');
  Object.keys(AVENUES).sort().forEach(name=>{
    if(name.toLowerCase().includes(q)){
      const li = document.createElement('li');
      li.textContent = name;
      li.onclick = ()=>{input.value=name;container.classList.remove('active');calculateTrip();};
      ul.appendChild(li);
    }
  });
  
  if(ul.children.length>0){
    container.appendChild(ul);
    container.classList.add('active');
  }
}

function findAvenue(name){
  if(!name) return null;
  const n = norm(name);
  for(const k of Object.keys(AVENUES)){
    if(norm(k)===n) return {name:k,...AVENUES[k]};
  }
  for(const k of Object.keys(AVENUES)){
    if(norm(k).includes(n)) return {name:k,...AVENUES[k]};
  }
  return null;
}

// TRIP LOGIC
function calculateTrip(){
  const p = findAvenue(document.getElementById('pickup').value);
  const d = findAvenue(document.getElementById('destination').value);
  
  if(!p || !d){showToast('Selecione locais válidos','error');return;}
  
  const km = haversineKm(p.lat,p.lon,d.lat,d.lon);
  const price = calcPrice(km);
  const time = estimateTime(km);
  
  currentTripData = {
    pickup:p.name, pickupLat:p.lat, pickupLon:p.lon,
    destination:d.name, destLat:d.lat, destLon:d.lon,
    distance:km.toFixed(2), price:price, estimatedTime:time
  };
  
  document.getElementById('distanceText').textContent = km.toFixed(1)+' km';
  document.getElementById('timeText').textContent = time+' min';
  document.getElementById('priceText').textContent = price;
  document.getElementById('priceDisplay').style.display = 'block';
  document.getElementById('requestBtn').style.display = 'flex';
  showToast('Rota calculada!','success');
}

function requestTrip(){
  if(!currentTripData || !currentUser) return;
  
  currentTripId = 'trip_'+Date.now()+'_'+Math.random().toString(36).substr(2,9);
  
  const trip = {
    id: currentTripId,
    passengerId: currentUser.phone,
    passengerName: currentUser.name,
    passengerRating: currentUser.rating,
    status: 'searching',
    createdAt: Date.now(),
    driverId: null,
    ...currentTripData
  };
  
  db.ref('trips/'+currentTripId).set(trip).then(()=>{
    db.ref('activeTrips/'+currentTripId).set({
      tripId: currentTripId,
      passengerId: currentUser.phone,
      passengerName: currentUser.name,
      pickup: trip.pickup,
      destination: trip.destination,
      price: trip.price,
      distance: trip.distance,
      status: 'searching',
      createdAt: Date.now()
    });
    
    showSection('searchingSection');
    listenToTrip(currentTripId);
  });
}

function listenToTrip(tripId){
  if(tripListener) tripListener.off();
  tripListener = db.ref('trips/'+tripId).on('value',snap=>{
    const trip = snap.val();
    if(!trip) return;
    updateTripUI(trip);
  });
}

function updateTripUI(trip){
  if(trip.status==='searching') return;
  
  if(trip.status==='completed'){
    showCompletedUI(trip);
    return;
  }
  
  showSection('activeTripSection');
  const container = document.getElementById('activeTripContent');
  
  const statusMap = {
    'accepted': {text:'Motorista a caminho', badge:'accepted', action:''},
    'arrived': {text:'Motorista chegou!', badge:'arrived', action:'<button class="actionBtn btn-success" onclick="confirmPickup()" style="margin-top:16px"><span>✓</span> Confirmar Embarque</button>'},
    'driving': {text:'Em viagem', badge:'driving', action:''}
  };
  
  const s = statusMap[trip.status] || statusMap['accepted'];
  
  container.innerHTML = `
    <div class="status-card">
      <div class="status-header">
        <span class="status-badge ${s.badge}">${s.text}</span>
      </div>
      <div style="margin:16px 0">
        <div style="display:flex;justify-content:space-between;margin-bottom:8px">
          <span style="color:var(--text-secondary)">De:</span>
          <span style="font-weight:600">${trip.pickup}</span>
        </div>
        <div style="display:flex;justify-content:space-between">
          <span style="color:var(--text-secondary)">Para:</span>
          <span style="font-weight:600">${trip.destination}</span>
        </div>
      </div>
      ${trip.driverId?`
      <div class="driver-info">
        <div class="driver-avatar">👤</div>
        <div class="driver-details">
          <div class="driver-name">${trip.driverName}</div>
          <div class="driver-plate">${trip.driverPlate}</div>
          <div class="driver-rating">⭐ ${trip.driverRating}</div>
        </div>
        <button class="call-btn" onclick="window.open('tel:${trip.driverPhone}')">📞</button>
      </div>
      `:''}
      ${s.action}
      <button class="actionBtn btn-danger" onclick="cancelTrip()" style="margin-top:8px;background:rgba(255,71,87,0.2)"><span>❌</span> Cancelar</button>
    </div>
  `;
}

function confirmPickup(){
  if(!currentTripId) return;
  db.ref('trips/'+currentTripId).update({status:'driving',startedAt:Date.now()});
  db.ref('activeTrips/'+currentTripId).update({status:'driving'});
}

function showCompletedUI(trip){
  showSection('completedSection');
  document.getElementById('finalPrice').textContent = trip.finalPrice || trip.price;
}

function rateTrip(rating){
  document.querySelectorAll('.star').forEach((s,i)=>{
    s.classList.toggle('active',i<rating);
  });
  document.getElementById('ratingText').textContent = 'Obrigado pela avaliação!';
  if(currentTripId){
    db.ref('trips/'+currentTripId).update({passengerRating:rating,ratedAt:Date.now()});
  }
}

function finishTrip(){
  currentTripId = null;
  currentTripData = null;
  document.getElementById('pickup').value = '';
  document.getElementById('destination').value = '';
  document.getElementById('priceDisplay').style.display = 'none';
  document.getElementById('requestBtn').style.display = 'none';
  document.querySelectorAll('.star').forEach(s=>s.classList.remove('active'));
  showMenu();
  showToast('Viagem concluída!','success');
}

function cancelTrip(){
  if(!currentTripId) return;
  if(!confirm('Cancelar viagem?')) return;
  db.ref('trips/'+currentTripId).update({status:'cancelled',cancelledAt:Date.now(),cancelledBy:'passenger'});
  db.ref('activeTrips/'+currentTripId).remove();
  currentTripId = null;
  showMenu();
  showToast('Viagem cancelada','info');
}

function cancelRequest(){
  cancelTrip();
}

function checkActiveTrip(){
  if(!currentUser) return;
  db.ref('trips').orderByChild('passengerId').equalTo(currentUser.phone).once('value',snap=>{
    const trips = snap.val();
    if(trips){
      for(const id in trips){
        const t = trips[id];
        if(['searching','accepted','arrived','driving'].includes(t.status)){
          currentTripId = id;
          if(t.status==='searching') showSection('searchingSection');
          listenToTrip(id);
          break;
        }
      }
    }
  });
}

function loadHistory(){
  if(!currentUser) return;
  const list = document.getElementById('historyList');
  list.innerHTML = '<div class="loading-container"><div class="spinner" style="width:40px;height:40px"></div><p>A carregar...</p></div>';
  
  db.ref('trips').orderByChild('passengerId').equalTo(currentUser.phone).once('value',snap=>{
    const trips = snap.val();
    if(!trips){
      list.innerHTML = '<p style="text-align:center;color:var(--text-secondary)">Sem viagens ainda</p>';
      return;
    }
    
    const arr = Object.values(trips).sort((a,b)=>b.createdAt-a.createdAt);
    list.innerHTML = arr.map(t=>`
      <div class="history-item">
        <div class="history-icon">🚕</div>
        <div class="history-details">
          <div class="history-route">${t.pickup} → ${t.destination}</div>
          <div class="history-meta">
            <span>${new Date(t.createdAt).toLocaleDateString('pt-PT')}</span>
            <span>${t.status==='completed'?'✓ Concluída':t.status}</span>
          </div>
        </div>
        <div class="history-price">${t.price} MTN</div>
      </div>
    `).join('');
  });
}

// INIT
checkStoredLogin();
</script>
