  const tripData = {
    id: tripId,
    passengerId: currentUser.phone,
    passengerName: currentUser.name,
    ...currentTripData,
    status: 'searching',
    createdAt: Date.now(),
    driverId: null,
    driverName: null,
    driverPhone: null,
    driverPlate: null,
    driverRating: null,
    startedAt: null,
    completedAt: null,
    actualPrice: currentTripData.price
  };
  
  database.ref('trips/' + tripId).set(tripData).then(()=>{
    // Add to active trips list
    database.ref('activeTrips/' + tripId).set({
      passengerId: currentUser.phone,
      createdAt: Date.now(),
      status: 'searching'
    });
    
    showSearchingUI();
    listenToTrip(tripId);
    showToast('Pedido enviado! Procurando motoristas...', 'success');
  });
}

function showSearchingUI(){
  document.getElementById('requestForm').style.display = 'none';
  document.getElementById('searchingDriver').style.display = 'flex';
  document.getElementById('activeTrip').style.display = 'none';
}

function listenToTrip(tripId){
  if(tripListener) tripListener.off();
  
  tripListener = database.ref('trips/' + tripId).on('value', (snapshot)=>{
    const trip = snapshot.val();
    if(!trip) return;
    
    updateTripUI(trip);
  });
}

function updateTripUI(trip){
  const container = document.getElementById('activeTrip');
  
  if(trip.status === 'searching'){
    // Still searching, keep loading screen
    return;
  }
  
  // Hide searching, show trip details
  document.getElementById('searchingDriver').style.display = 'none';
  container.style.display = 'block';
  
  let statusText = '';
  let statusClass = '';
  let showDriver = false;
  let actionButton = '';
  
  switch(trip.status){
    case 'accepted':
      statusText = 'Motorista a caminho';
      statusClass = 'accepted';
      showDriver = true;
      actionButton = '<button class="actionBtn btn-secondary" onclick="callDriver()"><span>📞</span> Ligar Motorista</button>';
      break;
    case 'arrived':
      statusText = 'Motorista chegou!';
      statusClass = 'arrived';
      showDriver = true;
      actionButton = '<button class="actionBtn btn-success" onclick="confirmPickup()"><span>✓</span> Confirmar Embarque</button>';
      break;
    case 'driving':
      statusText = 'Em viagem';
      statusClass = 'driving';
      showDriver = true;
      actionButton = '<div style="text-align:center;color:var(--text-secondary);padding:12px">🚗 A caminho do destino...</div>';
      break;
    case 'completed':
      showCompletedUI(trip);
      return;
    case 'cancelled':
      showToast('Viagem cancelada', 'error');
      resetTrip();
      return;
  }
  
  let driverHtml = '';
  if(showDriver && trip.driverId){
    driverHtml = `
      <div class="driver-info">
        <div class="driver-avatar">👤</div>
        <div class="driver-details">
          <div class="driver-name">${trip.driverName || 'Motorista'}</div>
          <div class="driver-plate">🚗 ${trip.driverPlate || 'Matrícula não disponível'}</div>
          <div class="driver-rating">⭐ ${trip.driverRating || '5.0'}</div>
        </div>
        <button class="call-btn" onclick="callDriver('${trip.driverPhone}')">📞</button>
      </div>
    `;
  }
  
  container.innerHTML = `
    <div class="status-card">
      <div class="status-header">
        <span class="status-badge ${statusClass}">${statusText}</span>
        <span class="status-time">${new Date().toLocaleTimeString('pt-PT', {hour:'2-digit', minute:'2-digit'})}</span>
      </div>
      
      <div class="trip-route">
        <div class="route-dot pickup"></div>
        <div class="route-line"></div>
        <div class="route-dot dest"></div>
      </div>
      
      <div style="display:flex;justify-content:space-between;margin-bottom:16px">
        <div class="location-text">
          ${trip.pickup}
          <small>Recolha</small>
        </div>
        <div class="location-text" style="text-align:right">
          ${trip.destination}
          <small>Destino</small>
        </div>
      </div>
      
      <div class="info-grid">
        <div class="info-box">
          <div class="info-label">Distância</div>
          <div class="info-value">${trip.distance} km</div>
        </div>
        <div class="info-box">
          <div class="info-label">Preço</div>
          <div class="info-value" style="color:var(--secondary)">${trip.actualPrice || trip.price} MTN</div>
        </div>
      </div>
      
      ${driverHtml}
      
      <div style="margin-top:16px">
        ${actionButton}
      </div>
      
      ${trip.status !== 'completed' ? `
        <button class="actionBtn btn-danger" onclick="cancelTrip()" style="margin-top:8px;background:rgba(255,71,87,0.2)">
          <span>❌</span> Cancelar Viagem
        </button>
      ` : ''}
    </div>
  `;
}

