  if(phone){
    window.open('tel:' + phone);
  }else{
    showToast('Número do motorista não disponível', 'error');
  }
}

function confirmPickup(){
  if(!currentTripId) return;
  database.ref('trips/' + currentTripId).update({
    status: 'driving',
    startedAt: Date.now()
  });
  showToast('Viagem iniciada!', 'success');
}

function showCompletedUI(trip){
  document.getElementById('searchingDriver').style.display = 'none';
  document.getElementById('activeTrip').style.display = 'none';
  document.getElementById('requestForm').style.display = 'none';
  document.getElementById('tripCompleted').style.display = 'block';
  document.getElementById('finalPrice').textContent = trip.actualPrice || trip.price;
}

function rateTrip(rating){
  const stars = document.querySelectorAll('.star');
  stars.forEach((star, index)=>{
    if(index < rating){
      star.classList.add('active');
    }else{
      star.classList.remove('active');
    }
  });
  document.getElementById('ratingText').textContent = 'Obrigado pela avaliação!';
  
  if(currentTripId){
    database.ref('trips/' + currentTripId).update({
      passengerRating: rating,
      ratedAt: Date.now()
    });
  }
}

function finishTrip(){
  resetTrip();
  showToast('Obrigado por usar MovaGo!', 'success');
}

