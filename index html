function setupAutocomplete(){
  const pickup = document.getElementById('pickup');
  const destination = document.getElementById('destination');
  
  pickup.addEventListener('input', ()=> showSuggestions(pickup, 'pickupList'));
  destination.addEventListener('input', ()=> showSuggestions(destination, 'destList'));
  
  document.addEventListener('click', (e)=>{
    if(!e.target.closest('.formGroup')){
      document.querySelectorAll('.autocompleteList').forEach(el => el.classList.remove('active'));
    }
  });
}

function showSuggestions(inputEl, listId){
  const q = inputEl.value.trim().toLowerCase();
  const container = document.getElementById(listId);
  container.innerHTML = '';
  if(q.length < 1){
    container.classList.remove('active');
    return;
  }
  
  const ul = document.createElement('ul');
  const names = Object.keys(AVENUES).sort();
  let added = 0;
  
  for(const name of names){
    if(name.toLowerCase().includes(q)){
      const li = document.createElement('li');
      li.textContent = name;
      li.onclick = ()=>{
        inputEl.value = name;
        container.classList.remove('active');
        calculateTrip();
      };
      ul.appendChild(li);
      added++;
      if(added >= 8) break;
    }
  }
  
  if(added > 0){
    container.appendChild(ul);
    container.classList.add('active');
  }
}

function findAvenue(name){
  if(!name) return null;
  const n = norm(name);
  for(const k of Object.keys(AVENUES)){
    if(norm(k) === n) return {name:k, ...AVENUES[k]};
  }
  for(const k of Object.keys(AVENUES)){
    if(norm(k).includes(n)) return {name:k, ...AVENUES[k]};
  }
  return null;
}

// ==================== TRIP LOGIC ====================
let currentTripData = null;

function calculateTrip(){
  const pickup = findAvenue(document.getElementById('pickup').value);
  const dest = findAvenue(document.getElementById('destination').value);
  
  if(!pickup || !dest){
    showToast('Selecione locais válidos', 'error');
    return;
  }
  
  const km = haversineKm(pickup.lat, pickup.lon, dest.lat, dest.lon);
  const price = calcPriceFromKm(km);
  const time = estimateTime(km);
  
  currentTripData = {
    pickup: pickup.name,
    pickupLat: pickup.lat,
    pickupLon: pickup.lon,
    destination: dest.name,
    destLat: dest.lat,
    destLon: dest.lon,
    distance: km.toFixed(2),
    price: price,
    estimatedTime: time
  };
  
  document.getElementById('distanceText').textContent = km.toFixed(1) + ' km';
  document.getElementById('timeText').textContent = time + ' min';
  document.getElementById('priceText').textContent = price;
  document.getElementById('priceDisplay').style.display = 'block';
  document.getElementById('requestBtn').style.display = 'flex';
  
  showToast('Rota calculada!', 'success');
}

