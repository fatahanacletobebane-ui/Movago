  currentTripId = null;
  currentTripData = null;
  if(tripListener){
    tripListener.off();
    tripListener = null;
  }
  
  document.getElementById('requestForm').style.display = 'block';
  document.getElementById('searchingDriver').style.display = 'none';
  document.getElementById('activeTrip').style.display = 'none';
  document.getElementById('tripCompleted').style.display = 'none';
  document.getElementById('pickup').value = '';
  document.getElementById('destination').value = '';
  document.getElementById('priceDisplay').style.display = 'none';
  document.getElementById('requestBtn').style.display = 'none';
  document.getElementById('distanceText').textContent = '— km';
  document.getElementById('timeText').textContent = '— min';
}

function cancelRequest(){
  if(!currentTripId) return;
  
  if(confirm('Tem certeza que deseja cancelar?')){
    database.ref('trips/' + currentTripId).update({
      status: 'cancelled',
      cancelledAt: Date.now(),
      cancelledBy: 'passenger'
    });
    database.ref('activeTrips/' + currentTripId).remove();
    resetTrip();
    showToast('Pedido cancelado', 'info');
  }
}

function cancelTrip(){
  cancelRequest();
}

function checkActiveTrip(){
  // Check if user has any active trip
  database.ref('trips').orderByChild('passengerId').equalTo(currentUser.phone).once('value', (snapshot)=>{
    const trips = snapshot.val();
    if(trips){
      for(const tripId in trips){
        const trip = trips[tripId];
        if(['searching', 'accepted', 'arrived', 'driving'].includes(trip.status)){
          currentTripId = tripId;
          if(trip.status === 'searching'){
            showSearchingUI();
          }
          listenToTrip(tripId);
          break;
        }
      }
    }
  });
}

function toggleUserMenu(){
  if(confirm('Deseja sair da conta?')){
    logout();
